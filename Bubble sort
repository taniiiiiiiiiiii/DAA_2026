include <stdio.h>
#include <stdlib.h>

int n, i, j, a[10], temp;

void read() {
    printf("Enter elements\n");
    for (i =0; i< n;i++) {

        scanf("%d", &a[i]);
    }
}

void display() {
    printf("Array elements:\n");
    for (i=0; i<n;i++) {
        printf("%d\t", a[i]);
    }
    printf("\n");
}

void sort() {
    for (i=0; i<n-1; i++) {
        for (j=0; j<n-i-1; j++) {
            if (a[j] > a[j+1]) {
                temp = a[j];
                a[j] = a[j+1];
                a[j+1]=temp;
            }
        }
    }

}

int main() {
    int choice;

    while (1) {
        printf("\n1.Read\n2.Display\n3.Sort\n4.Exit\n");
        scanf("%d", &choice);

        switch (choice) {
            case 1:
                printf("Enter the size of the array : ");
                scanf("%d", &n);
                read();
                break;

            case 2:
                display();
                break;

            case 3:
                sort();
                break;

            case 4:
                exit(0);

            default:
                printf("Invalid choice\n");
        }
    }

    return 0;
}
