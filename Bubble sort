#include <stdio.h>

void read(int a[], int n) {
    printf("Enter elements:\n");
    for (int i = 0; i < n; i++) {
        scanf("%d", &a[i]);
    }
}

void display(int a[], int n) {
    printf("Array elements:\n");
    for (int i = 0; i < n; i++) {
        printf("%d\t", a[i]);
    }
    printf("\n");
}

void sort(int a[], int n) {
    int temp;
    for (int i = 0; i < n - 1; i++) {
        for (int j = 0; j < n - i - 1; j++) {
            if (a[j] > a[j + 1]) {
                temp = a[j];
                a[j] = a[j + 1];
                a[j + 1] = temp;
            }
        }
    }
}

int main() {
    int n, a[10];

    printf("Enter size of array: ");
    scanf("%d", &n);

    read(a, n);
    
    printf("\nBefore sorting:\n");
    display(a, n);

    sort(a, n);

    printf("\nAfter sorting:\n");
    display(a, n);

    return 0;
}
