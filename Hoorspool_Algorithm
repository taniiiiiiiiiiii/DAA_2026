#include <stdio.h>
#include <string.h>

#define MAX 256

void shiftTable(char P[],int m,int Table[]) {
    int i;
    for (i=0; i <MAX; i++) {
        Table[i]=m;
    }
    for (i=0; i<m -1; i++) {
        Table[(unsigned char)P[i]] = m - 1 - i;
    }
}

int HorspoolMatching(char P[], char T[]) {
    int m = strlen(P);
    int n = strlen(T);
    int Table[MAX];
    int i, k;

    shiftTable(P,m,Table);

    i =m-1;

    while (i<=n-1) {
        k = 0;
        while (k<=m-1 && P[m-1-k] ==T[i-k]) {
            k++;
        }
        if (k==m) {
            return i-m +1;
        } else {
            i=i+Table[(unsigned char)T[i]];
        }
    }
    return -1;
}

int main() {
    char text[1000],pattern[1000];

    printf("Enter the text: ");
    gets(text, sizeof(text), stdin);

    printf("Enter the pattern to search: ");
    gets(pattern, sizeof(pattern), stdin);


    int result = HorspoolMatching(pattern, text);

    if (result != -1) {
        printf("Pattern found starting at index: %d\n", result);
    } else {
        printf("Pattern not found in the given text\n");
    }

    return 0;
}
