#include<stdio.h>
void read(int a[],int n){
    for(int i=0;i<n;i++){
        scanf("%d",&a[i]);
    }
}
void display(int a[],int n){
    for(int i=0;i<n;i++){
        printf("%d\t",a[i]);
    }
    printf("\n");
}
void merge(int a[],int low,int mid,int high){
    int temp[20];
    int i=low;
    int k=low;
    int j=mid+1;
    while(i<=mid && j<=high){
        if(a[i]<a[j]){
            temp[k]=a[i];
            i++;
            k++;
            
        }
        else{
        temp[k]=a[j];
        j++;
        k++;}
    }
    while(i<=mid){
        temp[k]=a[i];
        i++;
        k++;
        
    }
    while(j<=high){
        temp[k]=a[j];
        j++;
        k++;
    }
    for(i =low;i<=high;i++){
       a[i]=temp[i];
    }
}



void mergesort(int a[] ,int low,int high){
    if(low<high){
        int mid=(low+high)/2;
    mergesort(a,low,mid);
    mergesort(a,mid+1,high);
    merge(a,low,mid,high);
    }
}
int main(){
    int n,i,a[20];
    printf("enter the num of elem \n");
    scanf("%d",&n);
    printf("enter the elements : \n");
    read(a,n);
    printf("before sorting :\n");
    display(a,n);
    mergesort(a,0,n-1);
    printf("after sorting:\n");
    display(a,n);
    return 0;
}

