#include<stdio.h>
int hoarePartition(int a[],int l,int r){
    int p =a[l];
    int i=l;
    int j=r+1;
    do{
        i++;
        
    }while (a[i]<p && i<r);
    do{
        j--;
        
    }while(a[j]>p);
    if(i<j){
        int temp=a[i];
        a[i]=a[j];
        a[j]=temp;
    }
    int temp=a[l];
    a[l]=a[j];
    a[j]=temp;
    return j;
}
void quicksort(int a[],int l ,int r){
    if(l<r){
    int s=hoarePartition(a,l,r);
    quicksort(a,l,s-1);
    quicksort(a,s+1,r);
        
    }
}
    
