#include <stdio.h>
#include <stdlib.h>
#define MAX 100
void warshall(int R[MAX][MAX],int n){
    int i,j,k;
    for(k=0;k<n;k++){
        for(i=0;i<n;i++){
        for(j=0;j<n;j++){
        R[i][j]=R[i][j] || (R[i][k] && R[k][j]);

        }

        }
    }

}

